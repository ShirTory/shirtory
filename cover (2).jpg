<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>ShirTory Admin — Login</title>
  <link rel="icon" type="image/png" href="images/logo.png"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
  <script>
    const firebaseConfig = {
      apiKey: "AIzaSyB0NMwYgWK7Zr76urLEkcQfv1pTDXJ4SmM",
      authDomain: "shirtory-4bcae.firebaseapp.com",
      projectId: "shirtory-4bcae",
      storageBucket: "shirtory-4bcae.firebasestorage.app",
      messagingSenderId: "634050233913",
      appId: "1:634050233913:web:3b46991a205f3160956fe8",
      measurementId: "G-5YPCEJ34BE"
    };
    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();
  </script>
  <style>
    :root{--bg:#0a0a0a;--surface:#141414;--ink:#f0ece4;--muted:#888;--accent:#C9A84C;--accent2:#7B1A1A;--border:#242424;--radius:10px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:var(--bg);color:var(--ink);font-family:'Inter',sans-serif;min-height:100vh;display:flex;flex-direction:column}
    a{color:inherit;text-decoration:none}
    button{cursor:pointer;border:none;font:inherit}

    .login-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:40px 20px}
    .login-box{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:48px 40px;width:100%;max-width:420px}
    .login-logo{text-align:center;margin-bottom:32px}
    .login-logo h1{font-family:'Playfair Display',serif;font-size:2rem;font-weight:700}
    .login-logo h1 span{color:var(--accent2)}
    .login-logo p{color:var(--muted);font-size:.85rem;margin-top:6px}

    .login-tabs{display:flex;background:#0f0f0f;border-radius:8px;padding:4px;margin-bottom:16px;gap:4px}
    .tab-btn{flex:1;padding:9px;border-radius:6px;font-size:.82rem;font-weight:500;color:var(--muted);background:none;transition:all .2s;text-align:center}
    .tab-btn.active{background:var(--accent2);color:#fff}

    .role-hint{background:#7B1A1A15;border:1px solid #7B1A1A40;border-radius:8px;padding:10px 14px;font-size:.76rem;color:#e8b4b4;margin-bottom:18px;text-align:center}

    label{display:block;font-size:.78rem;font-weight:500;color:var(--muted);letter-spacing:.05em;text-transform:uppercase;margin-bottom:6px;margin-top:18px}
    input{width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:var(--radius);background:#0f0f0f;color:var(--ink);font:inherit;font-size:.92rem;transition:border-color .2s}
    input:focus{outline:none;border-color:var(--accent)}
    .pw-wrap{position:relative}
    .pw-toggle{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;color:var(--muted);font-size:.85rem;padding:4px}

    .btn-login{width:100%;margin-top:26px;padding:14px;background:var(--accent2);color:#fff;border-radius:var(--radius);font-size:.92rem;font-weight:600;letter-spacing:.04em;transition:opacity .2s}
    .btn-login:hover{opacity:.88}
    .btn-login:disabled{opacity:.6;cursor:not-allowed}
    .error-msg{color:#ff6b6b;font-size:.82rem;text-align:center;margin-top:14px;display:none;background:#ff6b6b15;border:1px solid #ff6b6b30;border-radius:8px;padding:10px}

    .back-link{text-align:center;margin-top:20px;font-size:.8rem;color:var(--muted)}
    .back-link a{color:var(--accent)}
    .footer-txt{text-align:center;padding:20px;font-size:.75rem;color:var(--border)}
  </style>
</head>
<body>
<div class="login-wrap">
  <div class="login-box">
    <div class="login-logo">
      <h1>Shir<span>Tory</span></h1>
      <p>Admin Panel — Secure Login</p>
    </div>

    <div class="login-tabs">
      <button class="tab-btn active" id="tabAdmin" onclick="setRoleHint('admin',this)">🔐 Master Admin</button>
      <button class="tab-btn" id="tabMod" onclick="setRoleHint('moderator',this)">🛡️ Moderator</button>
    </div>
    <div class="role-hint" id="roleHint">Just enter your username &amp; password below — you'll be logged in with whatever role your account has. No need to match the tab.</div>

    <label>Username</label>
    <input type="text" id="loginUserField" placeholder="Enter username" autocomplete="username" autocorrect="off" autocapitalize="off" spellcheck="false" onkeydown="if(event.key==='Enter')document.getElementById('loginPassField').focus()"/>

    <label>Password</label>
    <div class="pw-wrap">
      <input type="password" id="loginPassField" placeholder="Enter password" autocomplete="current-password" autocorrect="off" autocapitalize="off" spellcheck="false" onkeydown="if(event.key==='Enter')login()"/>
      <button class="pw-toggle" type="button" onclick="togglePW()">👁</button>
    </div>

    <button class="btn-login" id="loginBtn" onclick="login()" disabled>Loading…</button>
    <p class="error-msg" id="errorMsg"></p>

    <p class="back-link"><a href="index.html">← Back to Store</a></p>
  </div>
</div>
<p class="footer-txt">ShirTory Admin Panel © 2026</p>

<script>
// ============================================================
// USERS — single source of truth for login, synced via Firebase
// (Firestore doc shirtory/users) so every device sees the same
// accounts. Master Admin manages this list from the Dashboard.
// ============================================================
const DEFAULT_USERS = [
  {username:'shirtory', password:'786786', role:'master_admin', name:'Master Admin'},
  {username:'mod1', password:'mod123', role:'moderator', name:'Moderator 1'},
];

let cloudUsers = null;   // populated once Firestore responds

function getUsers(){
  return (Array.isArray(cloudUsers) && cloudUsers.length) ? cloudUsers : DEFAULT_USERS;
}

db.collection('shirtory').doc('users').onSnapshot(doc=>{
  cloudUsers = (doc.exists && Array.isArray(doc.data().list)) ? doc.data().list : null;
  const btn = document.getElementById('loginBtn');
  if(btn && btn.disabled){ btn.disabled = false; btn.textContent = 'Login →'; }
}, err=>{
  console.error('User sync error:', err);
  // Even if the cloud read fails (e.g. offline), fall back to DEFAULT_USERS
  // so the Master Admin account still works.
  const btn = document.getElementById('loginBtn');
  if(btn && btn.disabled){ btn.disabled = false; btn.textContent = 'Login →'; }
});

// Tabs are now just a visual hint — they no longer block login.
function setRoleHint(role, btn){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function togglePW(){
  const inp = document.getElementById('loginPassField');
  inp.type = inp.type==='password' ? 'text' : 'password';
}

function showError(msg){
  const errEl = document.getElementById('errorMsg');
  errEl.textContent = msg;
  errEl.style.display = 'block';
}

function login(){
  const username = document.getElementById('loginUserField').value.trim();
  const password = document.getElementById('loginPassField').value;
  const errEl = document.getElementById('errorMsg');
  errEl.style.display = 'none';

  if(!username || !password){
    showError('❌ Username ও Password দুটোই লিখুন');
    return;
  }

  const users = getUsers();
  // Case-insensitive username match so accidental Caps Lock etc. doesn't cause a false error.
  const user = users.find(u =>
    String(u.username).toLowerCase() === username.toLowerCase() &&
    String(u.password) === password
  );

  if(!user){
    showError('❌ Username অথবা Password ভুল হয়েছে। আবার চেষ্টা করুন।');
    return;
  }

  const btn = document.getElementById('loginBtn');
  btn.disabled = true; btn.textContent = 'একটু অপেক্ষা করুন…';

  sessionStorage.setItem('shirtory_session', JSON.stringify({
    username: user.username, role: user.role, name: user.name, loginTime: Date.now()
  }));
  window.location.href = 'dashboard.html';
}

// If a valid session already exists, skip straight to dashboard instead of
// showing the login form again.
(function autoRedirect(){
  try{
    const s = JSON.parse(sessionStorage.getItem('shirtory_session'));
    if(s && s.username && s.role){ window.location.href = 'dashboard.html'; }
  }catch(e){ /* ignore malformed session, just show login */ }
})();

window.onload = ()=>{ document.getElementById('loginUserField').focus(); };
</script>
</body>
</html>
